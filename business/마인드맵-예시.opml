<?xml version="1.0" encoding="UTF-8"?>
<!-- 채운 예시 (태오 사업 NTEOS) · "이 정도로 펼치면 된다"는 감을 잡는 용도.
     내 사업으로 바꿔 채운 뒤 텍스트/OPML 로 내보내 /cab-w1-departments 에 붙여넣으세요. -->
<opml version="2.0">
  <head>
    <title>내 사업 마인드맵 (예시 · NTEOS)</title>
  </head>
  <body>
    <outline text="내 사업 (NTEOS)">
      <outline text="① 사업 한 줄">
        <outline text="누구의: 나보다 한 걸음 늦은 1인 사업자"/>
        <outline text="어떤 문제: 방향은 있는데 실행·시스템이 안 잡혀 혼자 갈려나가는 것"/>
        <outline text="어떤 방법으로: AI 로 반복을 시스템화해 몰입할 일에 시간 쓰게"/>
        <outline text="사업·브랜드명: NTEOS (지식창업 + 실행 비즈니스 컨설팅 + 교육)"/>
      </outline>
      <outline text="② 꿈의 고객 한 명">
        <outline text="나이·상황·직업: 월매출 500~1000만, 본인 단독, 하루 12시간, 번아웃 직전 1인 사업자"/>
        <outline text="밤에 잠 못 드는 통증: 매출은 나는데 내가 시스템이라 내가 멈추면 다 멈춘다"/>
        <outline text="이미 시도했지만 안 된 것: 책·강의에 돈만 쓰고 실행으로 안 이어짐"/>
        <outline text="내가 주는 변화: 반복을 자동화해 살아있음 느끼는 일에 시간을 되찾음"/>
      </outline>
      <outline text="③ 반복업무 + 통증">
        <outline text="반복업무 1: 콘텐츠 1편 → 5채널 변형 (매주 / 3시간)"/>
        <outline text="반복업무 2: DM·댓글 응대 (매일 / 1시간)"/>
        <outline text="반복업무 3: 주간 매출·KPI 리포트 (매주 / 1시간)"/>
        <outline text="반복업무 4: 영수증·비용 정리 (매주 / 30분)"/>
        <outline text="반복업무 5: 무료 라이브 주제 기획 (매주 / 1시간)"/>
        <outline text="⭐ 가장 벗어나고 싶은 통증 1개: 콘텐츠 5채널 변형"/>
      </outline>
      <outline text="④ 평소 쓰는 도구 전부">
        <outline text="도구들: Claude Code, 노션, Supabase, Gmail, 인스타, 스레드, 유튜브, 캡컷, 볼타, 구글캘린더, 토스, 카카오 오픈채팅"/>
      </outline>
      <outline text="⑤ 내 톤 · 절대 금지어">
        <outline text="말투: 따뜻하고 솔직, 간결, 실행 위주, 가설→실험→측정"/>
        <outline text="자주 쓰는 단어: 살아있음, 한 걸음 늦은, 시스템화, 몰입"/>
        <outline text="금지어: 박힘/박제/자전, '실패' 프레임, 강매·결과집착 톤, 마침표 남발, 무의식"/>
      </outline>
      <outline text="⑥ 우선순위 · 목표 · 안 하는 것">
        <outline text="우선순위 1: CAB (4주 오프라인)"/>
        <outline text="우선순위 2: 30일 챌린지"/>
        <outline text="우선순위 3: 12주 1:1 코칭"/>
        <outline text="이번 분기 목표: 3개월 안 월 2,000만 구조"/>
        <outline text="안 하는 것: 강매, 결과 집착, 안 즐기는 작업 억지로"/>
      </outline>
    </outline>
  </body>
</opml>
